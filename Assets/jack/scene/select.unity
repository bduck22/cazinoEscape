  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC0AC\uC6A9 \uD589\uB3D9\uB825 : 2\n\uAE08\uC561 : \uBC30\uD305(\uBB34\uC81C\uD55C)\n\uADDC\uCE59
    \uC124\uBA85 : \uAE30\uBCF8\uC801\uC73C\uB85C \uC54C\uB824\uC9C4 \uBE14\uB799\uC7AD\uC774\uC9C0\uB9CC\n\u2664\u25C7\u2661\u2667\uB294
    \uD3B8\uC758\uC0C1 10\uC73C\uB85C \uD45C\uAE30\uB429\uB2C8\uB2E4.\n\uC2B9\uB9AC
    \uC870\uAC74\uC740 \uB51C\uB7EC\uC640 \uD50C\uB808\uC774\uC5B4\uC911 21\uC5D0
    \uC22B\uC790\uAC00 \n\uB354 \uAC00\uAE4C\uC6B4 \uC0AC\uB78C\uC774 \uC2B9\uB9AC\uD569\uB2C8\uB2E4.(\uBB34\uC2B9\uBD80
    O)\n\uB51C\uB7EC\uB294 \uCC98\uC74C 2\uC7A5\uC758 \uD569\uC774 16\uC774\uD558\uBA74
    \uCE74\uB4DC\uB97C\n\uD55C \uC7A5 \uB354 \uBF51\uC2B5\uB2C8\uB2E4.\nA\uB294 1
    \uB610\uB294 11\uB85C \uACC4\uC0B0\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\nA\uAC00
    \uC911\uBCF5\uC73C\uB85C \uB098\uC640\uB3C4 \uD558\uB098\uC758 \nA\uB9CC 11\uB85C
    \uACC4\uC0B0 \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uD50C\uB808\uC774\uC5B4\uC640
    \uB51C\n\uB7EC \uBAA8\uB450 1\uBC88\uB9CC \uCE74\uB4DC\uB97C \uBF51\uC744 \uC218
    \uC788\uC2B5\uB2C8\uB2E4.\n\uCE74\uB4DC\uB97C \uCD94\uAC00\uB85C \uBF51\uC744
    \uB54C \uD3EC\uAE30\uD558\uACE0 \uBC30\uD305\uAE08\uC758 \n\uC808\uBC18\uC744
    \uAC00\uC838\uAC08 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n(\uB2E4\uC74C \uD398\uC774\uC9C0\uC5D0\uC11C
    \uACC4\uC18D)"
